# Gemini Batch OCR Configuration
# 复制此文件为 .env 并填入你的配置

# ==================== Vertex 配置（vertex_ocr.py） ====================
# Vertex 项目与区域
GOOGLE_CLOUD_PROJECT=your_gcp_project_id
GOOGLE_CLOUD_LOCATION=global

# Vertex API key（可选）
# 只给 vertex_ocr.py 用，不会复用 GEMINI_API_KEY。
# 适合实时模式测试；Batch 模式会忽略该值并强制走 ADC + project/location。
# VERTEX_API_KEY=your_vertex_api_key

# Vertex 模型
# 常用:
#   - gemini-2.5-flash-lite  (默认，成本更低)
#   - gemini-2.5-flash       (更稳一些)
#   - gemini-2.5-pro         (质量更高，成本更高)
VERTEX_MODEL_NAME=gemini-2.5-flash-lite

# Vertex Batch 需要 GCS bucket
VERTEX_GCS_BUCKET=your_gcs_bucket_name
# 可选，默认 gemini-batch-by-Claude/vertex-ocr
VERTEX_GCS_PREFIX=gemini-batch-by-Claude/vertex-ocr
# 本地上传页面到 GCS 的并发数（越大越快，但也更容易触发本地网络/限流瓶颈）
GCS_UPLOAD_WORKERS=6

# 认证方式建议使用 ADC：
# export GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# 或先执行：
# gcloud auth application-default login

# 常用清理命令（vertex_ocr.py）：
# 仅清理远端 Batch Job 资源（不删 GCS 文件）
#   python vertex_ocr.py --cleanup-all-jobs
# 仅清理 GCS 输入/输出产物（保留 Job 记录）
#   python vertex_ocr.py --cleanup-gcs-artifacts
# 按单个 PDF 清理：
#   python vertex_ocr.py --file your.pdf --cleanup-gcs-artifacts

# ==================== API配置 ====================
GEMINI_API_KEY=your_gemini_api_key_here

# 模型选择
# 可用模型列表（价格已按 Gemini Developer API 官方页于 2026-03-21 核对）:
#   - gemini-3.1-flash-lite-preview  (默认，当前最便宜，适合大批量 OCR)
#   - gemini-3-flash-preview         (更强一些，但成本更高)
#   - gemini-2.5-flash               (稳定版，速度/成本平衡)
#   - gemini-2.5-flash-lite          (更便宜的稳定版)
#   - gemini-2.5-pro                 (高质量，但 Batch 成本明显更高)
#   - gemini-3.1-pro-preview         (高质量预览版，最贵)
MODEL_NAME=gemini-3.1-flash-lite-preview

# ==================== 实时模式配置 ====================
# PDF转图片DPI (越高越清晰，但处理更慢，建议200-300)
PDF_DPI=200
# PDF转图片线程数（可提高本地渲染速度）
PDF_RENDER_THREADS=4

# 并发处理数 (建议1-3，避免API限流)
MAX_WORKERS=1

# 失败重试次数
MAX_RETRIES=3

# 重试延迟(秒)
RETRY_DELAY=5

# 请求间隔(秒，避免限流)
REQUEST_DELAY=1.5

# ==================== Batch API 配置 ====================
# 每批最大页数 (建议30-50，避免单个JSONL文件过大)
BATCH_SIZE=50

# 轮询间隔(秒，检查Batch Job状态)
POLL_INTERVAL=30

# 同时处于 pending/running 的最大 Batch Job 数
# 默认不启用；需要时再取消注释，例如 10-30
# MAX_ACTIVE_BATCH_JOBS=20

# ==================== 语言配置 ====================
# 主要语言 (用于优化OCR提示词)
PRIMARY_LANGUAGE=Arabic

# 自定义OCR提示词 (可选，留空使用默认)
# OCR_PROMPT=
