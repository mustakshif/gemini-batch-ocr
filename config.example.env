# Gemini Batch OCR Configuration
# 复制此文件为 .env 并填入你的配置

# ==================== API配置 ====================
GEMINI_API_KEY=your_gemini_api_key_here

# 模型选择
# 可用模型列表（价格已按 Gemini Developer API 官方页于 2026-03-21 核对）:
#   - gemini-3.1-flash-lite-preview  (默认，当前最便宜，适合大批量 OCR)
#   - gemini-3-flash-preview         (更强一些，但成本更高)
#   - gemini-2.5-flash               (稳定版，速度/成本平衡)
#   - gemini-2.5-flash-lite          (更便宜的稳定版)
#   - gemini-2.5-pro                 (高质量，但 Batch 成本明显更高)
#   - gemini-3.1-pro-preview         (高质量预览版，最贵)
MODEL_NAME=gemini-3.1-flash-lite-preview

# ==================== 实时模式配置 ====================
# PDF转图片DPI (越高越清晰，但处理更慢，建议200-300)
PDF_DPI=200

# 并发处理数 (建议1-3，避免API限流)
MAX_WORKERS=1

# 失败重试次数
MAX_RETRIES=3

# 重试延迟(秒)
RETRY_DELAY=5

# 请求间隔(秒，避免限流)
REQUEST_DELAY=1.5

# ==================== Batch API 配置 ====================
# 每批最大页数 (建议30-50，避免单个JSONL文件过大)
BATCH_SIZE=50

# 轮询间隔(秒，检查Batch Job状态)
POLL_INTERVAL=30

# ==================== 语言配置 ====================
# 主要语言 (用于优化OCR提示词)
PRIMARY_LANGUAGE=Arabic

# 自定义OCR提示词 (可选，留空使用默认)
# OCR_PROMPT=
